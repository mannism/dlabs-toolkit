{
  "name": "dlabs-toolkit",
  "version": "0.0.0",
  "private": true,
  "description": "Diabolical Labs platform toolkit — shared TypeScript infrastructure. © Diabolical Labs",
  "author": "Diana Ismail <diana@deeismail.com> (https://deeismail.com)",
  "publisher": "Diabolical Labs",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mannism/dlabs-toolkit.git"
  },
  "homepage": "https://github.com/mannism/dlabs-toolkit#readme",
  "bugs": {
    "url": "https://github.com/mannism/dlabs-toolkit/issues"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset tag"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@changesets/cli": "^2.27.12",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.16.0",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "vite": "^6.0.0",
    "vitest": "^4.1.5"
  },
  "packageManager": "pnpm@9.15.0"
}
