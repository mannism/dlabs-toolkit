{
  "name": "@diabolicallabs/slack",
  "version": "1.0.0",
  "description": "Send-only Slack notifier. chat.postMessage + incoming webhook via @slack/web-api. Named error taxonomy, retry, pluggable logger, optional rate-limiter peer-dep. © Diabolical Labs",
  "author": "Diana Ismail <diana@deeismail.com> (https://deeismail.com)",
  "publisher": "Diabolical Labs",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mannism/dlabs-toolkit.git",
    "directory": "packages/slack"
  },
  "homepage": "https://github.com/mannism/dlabs-toolkit#readme",
  "bugs": {
    "url": "https://github.com/mannism/dlabs-toolkit/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "biome check ./src",
    "test": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@diabolicallabs/notifier-core": "workspace:*",
    "@slack/types": "^3.0.0",
    "@slack/web-api": "^7.17.0"
  },
  "peerDependencies": {
    "@diabolicallabs/rate-limiter": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "@diabolicallabs/rate-limiter": {
      "optional": true
    }
  },
  "devDependencies": {
    "@diabolicallabs/rate-limiter": "workspace:*",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "tsup": "^8.3.5",
    "vitest": "^4.1.10"
  }
}
