{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    // Target: Node 20+ LTS. ESM-only, no CJS output.
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    // Strict type safety — no exceptions
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,

    // Unused code as errors — enforced at type-check time
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    // Emit: each package emits into its own dist/
    // Per-package tsconfig sets "outDir": "dist" and "rootDir": "src"
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,

    // ESM interop
    // verbatimModuleSyntax is the canonical TS6 replacement for the legacy flags.
    // esModuleInterop and allowSyntheticDefaultImports are deprecated in TS6 (TS5107).
    // They remain set here explicitly for clarity during the TS6→7 transition window;
    // ignoreDeprecations: "6.0" silences the TS5107 errors. Also silences TS5101 for
    // baseUrl, which tsup's DTS rollup injects programmatically into the compiler options.
    "esModuleInterop": false,
    "allowSyntheticDefaultImports": false,
    "verbatimModuleSyntax": true,
    "ignoreDeprecations": "6.0",

    // Ensure consistent casing across OS
    "forceConsistentCasingInFileNames": true,

    "skipLibCheck": true
  }
}
